{
  "name": "zpan",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @zpan/server --filter @zpan/web --parallel dev",
    "build": "pnpm --filter @zpan/shared build && pnpm --filter @zpan/server build && pnpm --filter @zpan/web build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --parallel test",
    "test:cf": "pnpm --filter @zpan/server test:cf",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "e2e": "playwright test"
  },
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "workerd"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@playwright/test": "1.58.2",
    "@vitest/coverage-v8": "^4.1.2",
    "vitest": "^4.1.2"
  }
}
