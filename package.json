{
  "name": "zpan",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @zpan/server --filter @zpan/web --parallel dev",
    "build": "pnpm --filter @zpan/shared build && pnpm --filter @zpan/server build && pnpm --filter @zpan/web build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "e2e": "playwright test"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "workerd"
    ]
  },
  "devDependencies": {
    "@playwright/test": "1.58.2"
  }
}
